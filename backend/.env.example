APP_NAME=SuniPIP
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost
APP_TIMEZONE=Asia/Shanghai

# 平台信息
APP_PLATFORM_NAME=SuniPIP

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sunipip
DB_USERNAME=root
DB_PASSWORD=

CACHE_STORE=file
QUEUE_CONNECTION=database
SESSION_DRIVER=file

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1

# Spark 代理API
SPARK_API_URL=https://oapi.sparkproxy.com/v2/open/api
SPARK_SUPPLIER_NO=your_supplier_no
SPARK_AES_KEY=your_32_byte_aes_key_here
SPARK_API_VERSION=2.0

# 前端面板 URL（前后端分离部署时必填）
ADMIN_PORTAL_URL=https://admin-manager.sunipip.com
CUSTOMER_PORTAL_URL=https://user.sunipip.com

# CORS 允许的前端域名（逗号分隔，Cloudflare Pages 部署时必填）
# 包含 *.pages.dev 预览域名 + 自定义域名
CORS_ALLOWED_ORIGINS=https://taiyangip-admin.pages.dev,https://taiyangip-client.pages.dev,https://admin-manager.sunipip.com,https://user.sunipip.com,https://api-all.sunip.cc

# 企业微信 Webhook (到期提醒等)
WECHAT_WORK_WEBHOOK_URL=
